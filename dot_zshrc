for file in \
  "$HOME/.config/zsh/00-init.zsh" \
  "$HOME/.config/zsh/10-env.zsh" \
  "$HOME/.config/zsh/20-path.zsh" \
  "$HOME/.config/zsh/30-prompt.zsh" \
  "$HOME/.config/zsh/40-functions.zsh" \
  "$HOME/.config/zsh/50-integrations.zsh" \
  "$HOME/.config/zsh/90-local.zsh" \
  "$HOME/.config/zsh/99-secrets.zsh"
do
  [[ -r "$file" ]] && source "$file"
done
